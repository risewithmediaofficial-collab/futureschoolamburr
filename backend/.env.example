# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/future_school
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/future_school

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# File Upload (Choose one)
# Local Storage
UPLOAD_PATH=./uploads

# OR Cloudinary (uncomment to use)
# CLOUDINARY_NAME=your_cloudinary_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Admin
ADMIN_EMAIL=admin@futureschool.com
ADMIN_PASSWORD=Admin@123
